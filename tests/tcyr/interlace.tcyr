# tests/tcyr/interlace.tcyr — Adam7 interlace (chitra 0.2.1).
# Each case: ImageMagick encodes one source as non-interlaced AND Adam7-
# interlaced; chitra must decode both to byte-identical RGBA8. The
# non-interlaced path is trusted (0.2.0), so this validates the 7-pass
# deinterlace — including the sub-byte bit-scatter (gray4/gray1/pal2) and
# odd, non-multiple-of-8 dimensions. Standalone CPU suite.
include "src/lib.cyr"
include "lib/assert.cyr"

fn test_il_rgb8() {
    var lp = 0; var li = 0;
    var ep = 0; var ei = 0;
    var imp = chitra_png_decode(fx_il_rgb8_plain(&lp), lp, &ep);
    var imi = chitra_png_decode(fx_il_rgb8_inter(&li), li, &ei);
    assert(imp != 0, "rgb8 plain decodes");
    assert(imi != 0, "rgb8 interlaced decodes");
    assert_eq(chitra_image_width(imi), chitra_image_width(imp), "rgb8 w match");
    assert_eq(chitra_image_height(imi), chitra_image_height(imp), "rgb8 h match");
    # Adam7 result must equal the trusted non-interlaced result, byte-for-byte.
    var w = chitra_image_width(imp); var h = chitra_image_height(imp);
    var n = w * h * 4;
    var pp = chitra_image_pixels(imp); var pi = chitra_image_pixels(imi);
    var k = 0; var diff = 0;
    while (k < n) { if (load8(pp + k) != load8(pi + k)) { diff = diff + 1; } k = k + 1; }
    assert_eq(diff, 0, "rgb8 interlaced == non-interlaced (RGBA8)");
    return 0;
}

