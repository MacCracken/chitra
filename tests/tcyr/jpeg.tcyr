    var lo = 0;
    var b = fx_jpeg_dht_bad_class(&lo, 0x04);   # Th=4 (only 0..3 valid)
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "DHT table id 4 rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_DHT, "dht tableid err code");
    return 0;
}

fn test_reject_dht_oversub() {
    var lo = 0;
    var b = fx_jpeg_dht_oversub(&lo);
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "over-subscribed Huffman table rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_DHT, "dht oversub err code");
    return 0;
}

# Build a DC test table: 2 codes of length 1 -> symbol 0 = code "0", symbol 1 =
# code "1" (so DC size 0 = bit 0, DC size 1 = bit 1).
fn fx_dc_table(): i64 {
    var t = alloc(HT_SIZE);
    var bits[136];
    var i = 0;
    while (i <= 16) { store64(&bits + i * 8, 0); i = i + 1; }
    store64(&bits + 1 * 8, 2);
    store64(t + HT_COUNT, 2);
    store64(t + HT_HUFFVAL + 0 * 8, 0);
    store64(t + HT_HUFFVAL + 1 * 8, 1);
    _jpeg_huff_build(t, &bits);
    return t;
}

# Build an AC test table: 2 codes of length 2 -> symbol 0x00 (EOB) = code "00",
# symbol 0x01 (run 0, size 1) = code "01".
fn fx_ac_table(): i64 {
    var t = alloc(HT_SIZE);
    var bits[136];
    var i = 0;
    while (i <= 16) { store64(&bits + i * 8, 0); i = i + 1; }
    store64(&bits + 2 * 8, 2);
    store64(t + HT_COUNT, 2);
    store64(t + HT_HUFFVAL + 0 * 8, 0);
    store64(t + HT_HUFFVAL + 1 * 8, 1);
    _jpeg_huff_build(t, &bits);
    return t;
}

# Entropy stream encoding (with the tables above): DC size 1 -> "1", magnitude
# "1" (=> DC +1); AC "01"+"1" (run0/size1, +1 at position 1); AC "00" (EOB).
# Bits: 1 1 0 1 1 0 0, padded -> 0b11011000 = 0xD8.
fn fx_entropy_block(len_out): i64 {
    var b = alloc(1);
    store8(b + 0, 0xD8);
    store64(len_out, 1);
    return b;
}

fn test_extend() {
    assert_eq(_jpeg_extend(1, 1), 1, "extend(1,1)=1");
    assert_eq(_jpeg_extend(0, 1), 0 - 1, "extend(0,1)=-1");
    assert_eq(_jpeg_extend(5, 3), 5, "extend(5,3)=5");
    assert_eq(_jpeg_extend(2, 3), 0 - 5, "extend(2,3)=-5");
    assert_eq(_jpeg_extend(7, 3), 7, "extend(7,3)=7");
    assert_eq(_jpeg_extend(0, 0), 0, "extend(_,0)=0");
    return 0;
}

fn test_bitreader() {
    var buf[4];
    store8(&buf + 0, 0xB5);   # 1011 0101
    var rdr[48];
    _jpeg_br_init(&rdr, &buf, 1);
    assert_eq(_jpeg_br_bit(&rdr), 1, "bit0");
    assert_eq(_jpeg_br_bit(&rdr), 0, "bit1");
    assert_eq(_jpeg_br_bit(&rdr), 1, "bit2");
    assert_eq(_jpeg_br_bit(&rdr), 1, "bit3");
    assert_eq(_jpeg_br_bits(&rdr, 4), 5, "bits4..7 = 0101 = 5");
    return 0;
}

fn test_bitreader_stuffing() {
    var buf[4];
    store8(&buf + 0, 0xFF);
    store8(&buf + 1, 0x00);   # stuffed -> 0xFF is real data
    store8(&buf + 2, 0x80);   # 1000 0000
    var rdr[48];
    _jpeg_br_init(&rdr, &buf, 3);
    assert_eq(_jpeg_br_bits(&rdr, 8), 255, "stuffed 0xFF reads as 255");
    assert_eq(_jpeg_br_bit(&rdr), 1, "next bit from 0x80 = 1");
    assert_eq(_jpeg_br_marker(&rdr), 0, "no marker yet");
    return 0;
}

fn test_bitreader_marker() {
    var buf[4];
    store8(&buf + 0, 0x80);   # 1000 0000
    store8(&buf + 1, 0xFF);
    store8(&buf + 2, 0xD9);   # EOI marker
    var rdr[48];
    _jpeg_br_init(&rdr, &buf, 3);
    assert_eq(_jpeg_br_bit(&rdr), 1, "first data bit");
    assert_eq(_jpeg_br_bits(&rdr, 7), 0, "rest of 0x80");
    assert_eq(_jpeg_br_bits(&rdr, 4), 0, "bits after marker pad 0");
    assert_eq(_jpeg_br_marker(&rdr), 0xD9, "EOI marker detected");
    return 0;
}

fn test_decode_block() {
    var dct = fx_dc_table();
    var act = fx_ac_table();
    var lo = 0;
    var ent = fx_entropy_block(&lo);
    var rdr[48];
    _jpeg_br_init(&rdr, ent, lo);
    var zz = alloc(512);
    var err = 0;
    var dc = _jpeg_decode_block(&rdr, dct, act, 0, zz, &err);
    assert_eq(err, 0, "decode_block no error");
    assert_eq(dc, 1, "new DC predictor = 1");
    assert_eq(load64(zz + 0 * 8), 1, "zz[0] DC = 1");
    assert_eq(load64(zz + 1 * 8), 1, "zz[1] AC = 1");
    assert_eq(load64(zz + 2 * 8), 0, "zz[2] = 0 (EOB)");
    assert_eq(load64(zz + 63 * 8), 0, "zz[63] = 0");
    return 0;
}

fn test_decode_block_dc_predictor() {
    # Second block decoded against a non-zero predictor chains the DC value.
    var dct = fx_dc_table();
    var act = fx_ac_table();
    var lo = 0;
    var ent = fx_entropy_block(&lo);
    var rdr[48];
    _jpeg_br_init(&rdr, ent, lo);
    var zz = alloc(512);
    var err = 0;
    var dc = _jpeg_decode_block(&rdr, dct, act, 10, zz, &err);
    assert_eq(err, 0, "no error");
    assert_eq(dc, 11, "DC = pred(10) + diff(1) = 11");
    assert_eq(load64(zz + 0 * 8), 11, "zz[0] = 11");
    return 0;
}

# ---- bite 5: dequant + zig-zag + IDCT + level-shift ----

fn fx_zz_zero(): i64 {
    var z = alloc(512);
    var i = 0;
    while (i < 64) { store64(z + i * 8, 0); i = i + 1; }
    return z;
}

fn fx_quant_ones(): i64 {
    var q = alloc(512);
    var i = 0;
    while (i < 64) { store64(q + i * 8, 1); i = i + 1; }
    return q;
}

fn test_zigzag_table() {
    var t = _jpeg_zigzag_table();
    assert_eq(load64(t + 0 * 8), 0, "zigzag[0] = 0");
    assert_eq(load64(t + 1 * 8), 1, "zigzag[1] = 1");
    assert_eq(load64(t + 2 * 8), 8, "zigzag[2] = 8");
    assert_eq(load64(t + 3 * 8), 16, "zigzag[3] = 16");
    assert_eq(load64(t + 5 * 8), 2, "zigzag[5] = 2");
    assert_eq(load64(t + 63 * 8), 63, "zigzag[63] = 63");
    return 0;
}

fn test_descale() {
    assert_eq(_jpeg_descale(2048, 11), 1, "descale(2048,11)=1");
    assert_eq(_jpeg_descale(0 - 2048, 11), 0 - 1, "descale(-2048,11)=-1");
    assert_eq(_jpeg_descale(0, 18), 0, "descale(0,18)=0");
    return 0;
}

fn test_idct_zero() {
    var zz = fx_zz_zero();
    var q = fx_quant_ones();
    var out = alloc(512);
    _jpeg_idct_block(zz, q, out);
    assert_eq(load64(out + 0 * 8), 128, "zero block -> 128 at [0]");
    assert_eq(load64(out + 30 * 8), 128, "zero block -> 128 mid");
    assert_eq(load64(out + 63 * 8), 128, "zero block -> 128 at [63]");
    return 0;
}

fn test_idct_dc() {
    var q = fx_quant_ones();
    var out = alloc(512);
    var zz = fx_zz_zero();
    store64(zz + 0, 8);                 # DC = 8 -> round(8/8)+128 = 129, flat
    _jpeg_idct_block(zz, q, out);
    assert_eq(load64(out + 0 * 8), 129, "DC=8 -> 129 at [0]");
    assert_eq(load64(out + 63 * 8), 129, "DC=8 -> 129 flat");
    store64(zz + 0, 0 - 8);            # DC = -8 -> 127
    _jpeg_idct_block(zz, q, out);
    assert_eq(load64(out + 0 * 8), 127, "DC=-8 -> 127");
    store64(zz + 0, 2000);            # clamps high
    _jpeg_idct_block(zz, q, out);
    assert_eq(load64(out + 0 * 8), 255, "DC=2000 -> clamp 255");
    store64(zz + 0, 0 - 2000);        # clamps low
    _jpeg_idct_block(zz, q, out);
    assert_eq(load64(out + 0 * 8), 0, "DC=-2000 -> clamp 0");
    return 0;
}

fn test_dequant() {
    var q = fx_quant_ones();
    store64(q + 0, 2);                  # quant[0] = 2
    var out = alloc(512);
    var zz = fx_zz_zero();
    store64(zz + 0, 4);                 # raw DC 4 * quant 2 = 8 dequant -> 129
    _jpeg_idct_block(zz, q, out);
    assert_eq(load64(out + 0 * 8), 129, "dequant 4*2=8 -> 129");
    return 0;
}

# ---- bite 6a: end-to-end grayscale decode ----

# A complete 8x8 baseline grayscale JPEG. Quant table all 1s; Annex K.3.3 DC
# luminance Huffman table + a 2-symbol AC table; one entropy block encoding
# DC size 4 = +8 (-> flat round(8/8)+128 = 129) then EOB. EOI closes the stream.
fn fx_jpeg_gray_8x8(len_out): i64 {
    var b = alloc(150);
    var i = 0;
    # SOI
    store8(b + 0, 0xFF);
    store8(b + 1, 0xD8);
    # DQT: table 0, 64 ones
    store8(b + 2, 0xFF);
    store8(b + 3, 0xDB);
    store8(b + 4, 0x00);
    store8(b + 5, 0x43);
    store8(b + 6, 0x00);
    i = 0;
    while (i < 64) { store8(b + 7 + i, 1); i = i + 1; }
    # SOF0: 8x8, 1 component (id 1, H/V 1, Tq 0)
    store8(b + 71, 0xFF);
    store8(b + 72, 0xC0);
    store8(b + 73, 0x00);
    store8(b + 74, 0x0B);
    store8(b + 75, 0x08);
    store8(b + 76, 0x00);
    store8(b + 77, 0x08);
    store8(b + 78, 0x00);
    store8(b + 79, 0x08);
    store8(b + 80, 0x01);
    store8(b + 81, 0x01);
    store8(b + 82, 0x11);
    store8(b + 83, 0x00);
    # DHT: DC table 0 (Annex K) + AC table 0 (2 symbols)
    store8(b + 84, 0xFF);
    store8(b + 85, 0xC4);
    store8(b + 86, 0x00);
    store8(b + 87, 0x32);
    store8(b + 88, 0x00);                # DC Tc/Th
    store8(b + 89, 0x00);                # DC BITS L1..L16
    store8(b + 90, 0x01);
    store8(b + 91, 0x05);
    store8(b + 92, 0x01);
    store8(b + 93, 0x01);
    store8(b + 94, 0x01);
    store8(b + 95, 0x01);
    store8(b + 96, 0x01);
    store8(b + 97, 0x01);
    store8(b + 98, 0x00);
    store8(b + 99, 0x00);
    store8(b + 100, 0x00);
    store8(b + 101, 0x00);
    store8(b + 102, 0x00);
    store8(b + 103, 0x00);
    store8(b + 104, 0x00);
    i = 0;
    while (i < 12) { store8(b + 105 + i, i); i = i + 1; }   # DC huffval 0..11
    store8(b + 117, 0x10);               # AC Tc/Th = 0x10
    store8(b + 118, 0x00);               # AC BITS: L2 = 2, rest 0
    store8(b + 119, 0x02);
    i = 0;
    while (i < 14) { store8(b + 120 + i, 0); i = i + 1; }
    store8(b + 134, 0x00);               # AC huffval 0x00 (EOB), 0x01
    store8(b + 135, 0x01);
    # SOS: 1 component (Cs 1, Td/Ta 0), Ss 0 Se 63 Ah/Al 0
    store8(b + 136, 0xFF);
    store8(b + 137, 0xDA);
    store8(b + 138, 0x00);
    store8(b + 139, 0x08);
    store8(b + 140, 0x01);
    store8(b + 141, 0x01);
    store8(b + 142, 0x00);
    store8(b + 143, 0x00);
    store8(b + 144, 0x3F);
    store8(b + 145, 0x00);
    # entropy: "101"(DC size 4) + "1000"(=8) + "00"(EOB) -> 0xB0 0x00
    store8(b + 146, 0xB0);
    store8(b + 147, 0x00);
    # EOI
    store8(b + 148, 0xFF);
    store8(b + 149, 0xD9);
    store64(len_out, 150);
    return b;
}

fn test_decode_gray() {
    var lo = 0;
    var b = fx_jpeg_gray_8x8(&lo);
    var err = 0;
    var img = chitra_jpeg_decode(b, lo, &err);
    assert(img != 0, "grayscale decode returns an image");
    assert_eq(err, 0, "no error");
    assert_eq(chitra_image_width(img), 8, "width 8");
    assert_eq(chitra_image_height(img), 8, "height 8");
    assert_eq(chitra_image_channels(img), 4, "4 channels");
    var px = chitra_image_pixels(img);
    assert_eq(load8(px + 0), 129, "pixel0 R = 129 (flat DC=8)");
    assert_eq(load8(px + 1), 129, "pixel0 G = 129");
    assert_eq(load8(px + 2), 129, "pixel0 B = 129");
    assert_eq(load8(px + 3), 255, "pixel0 A = 255");
    assert_eq(load8(px + 63 * 4 + 0), 129, "pixel63 R = 129 (flat)");
    assert_eq(load8(px + 63 * 4 + 3), 255, "pixel63 A = 255");
    assert_eq(chitra_image_source_color_type(img), 257, "src ctype = 0x101 (JPEG gray)");
    return 0;
}

fn test_decode_gray_crop() {
    # Same stream, SOF dimensions patched to 5x5 -> still 1 MCU, cropped output.
    var lo = 0;
    var b = fx_jpeg_gray_8x8(&lo);
    store8(b + 77, 0x05);   # Y = 5
    store8(b + 79, 0x05);   # X = 5
    var err = 0;
    var img = chitra_jpeg_decode(b, lo, &err);
    assert(img != 0, "5x5 decode returns an image");
    assert_eq(chitra_image_width(img), 5, "width 5");
    assert_eq(chitra_image_height(img), 5, "height 5");
    var px = chitra_image_pixels(img);
    assert_eq(load8(px + 0), 129, "5x5 pixel0 = 129");
    assert_eq(load8(px + 24 * 4 + 0), 129, "5x5 last pixel = 129");
    return 0;
}

# ---- bite 6b: 3-component YCbCr 4:4:4 + color convert ----

# A complete 8x8 baseline 3-component (YCbCr, 4:4:4) JPEG. All components share
# quant table 0 (ones), DC table 0 (Annex K), AC table 0 (2 symbols). Entropy:
# Y block DC=+8 then EOB; Cb and Cr blocks DC=0 then EOB -> neutral chroma.
# So every pixel is Y=129, Cb=Cr=128 -> RGB (129,129,129).
fn fx_jpeg_ycc_8x8(len_out): i64 {
    var b = alloc(161);
    var i = 0;
    store8(b + 0, 0xFF);
    store8(b + 1, 0xD8);
    store8(b + 2, 0xFF);            # DQT table 0, ones
    store8(b + 3, 0xDB);
    store8(b + 4, 0x00);
    store8(b + 5, 0x43);
    store8(b + 6, 0x00);
    i = 0;
    while (i < 64) { store8(b + 7 + i, 1); i = i + 1; }
    store8(b + 71, 0xFF);           # SOF0 8x8, 3 components 4:4:4
    store8(b + 72, 0xC0);
    store8(b + 73, 0x00);
    store8(b + 74, 0x11);
    store8(b + 75, 0x08);
    store8(b + 76, 0x00);
    store8(b + 77, 0x08);
    store8(b + 78, 0x00);
    store8(b + 79, 0x08);
    store8(b + 80, 0x03);
    store8(b + 81, 0x01);           # comp 1: id 1, H/V 1, Tq 0
    store8(b + 82, 0x11);
    store8(b + 83, 0x00);
    store8(b + 84, 0x02);           # comp 2: id 2, H/V 1, Tq 0
    store8(b + 85, 0x11);
    store8(b + 86, 0x00);
    store8(b + 87, 0x03);           # comp 3: id 3, H/V 1, Tq 0
    store8(b + 88, 0x11);
    store8(b + 89, 0x00);
    store8(b + 90, 0xFF);           # DHT: DC table 0 (Annex K) + AC table 0
    store8(b + 91, 0xC4);
    store8(b + 92, 0x00);
    store8(b + 93, 0x32);
    store8(b + 94, 0x00);           # DC Tc/Th
    store8(b + 95, 0x00);           # DC BITS
    store8(b + 96, 0x01);
    store8(b + 97, 0x05);
    store8(b + 98, 0x01);
    store8(b + 99, 0x01);
    store8(b + 100, 0x01);
    store8(b + 101, 0x01);
    store8(b + 102, 0x01);
    store8(b + 103, 0x01);
    store8(b + 104, 0x00);
    store8(b + 105, 0x00);
    store8(b + 106, 0x00);
    store8(b + 107, 0x00);
    store8(b + 108, 0x00);
    store8(b + 109, 0x00);
    store8(b + 110, 0x00);
    i = 0;
    while (i < 12) { store8(b + 111 + i, i); i = i + 1; }   # DC huffval 0..11
    store8(b + 123, 0x10);          # AC Tc/Th
    store8(b + 124, 0x00);          # AC BITS: L2=2
    store8(b + 125, 0x02);
    i = 0;
    while (i < 14) { store8(b + 126 + i, 0); i = i + 1; }
    store8(b + 140, 0x00);          # AC huffval
    store8(b + 141, 0x01);
    store8(b + 142, 0xFF);          # SOS: 3 components
    store8(b + 143, 0xDA);
    store8(b + 144, 0x00);
    store8(b + 145, 0x0C);
    store8(b + 146, 0x03);
    store8(b + 147, 0x01);          # Cs 1, Td/Ta 0
    store8(b + 148, 0x00);
    store8(b + 149, 0x02);          # Cs 2, Td/Ta 0
    store8(b + 150, 0x00);
    store8(b + 151, 0x03);          # Cs 3, Td/Ta 0
    store8(b + 152, 0x00);
    store8(b + 153, 0x00);          # Ss
    store8(b + 154, 0x3F);          # Se
    store8(b + 155, 0x00);          # Ah/Al
    store8(b + 156, 0xB0);          # entropy: Y DC=+8/EOB, Cb DC=0/EOB, Cr DC=0/EOB
    store8(b + 157, 0x00);
    store8(b + 158, 0x00);
    store8(b + 159, 0xFF);          # EOI
    store8(b + 160, 0xD9);
    store64(len_out, 161);
    return b;
}

fn test_ycc_to_rgb() {
    var rgb[8];
    _jpeg_ycc_to_rgb(128, 128, 128, &rgb);
    assert_eq(load8(&rgb + 0), 128, "neutral R = 128");
    assert_eq(load8(&rgb + 1), 128, "neutral G = 128");
    assert_eq(load8(&rgb + 2), 128, "neutral B = 128");
    _jpeg_ycc_to_rgb(128, 128, 160, &rgb);
    assert_eq(load8(&rgb + 0), 173, "Cr+32 -> R = 173");
    assert_eq(load8(&rgb + 1), 105, "Cr+32 -> G = 105");
    assert_eq(load8(&rgb + 2), 128, "Cr+32 -> B = 128");
    _jpeg_ycc_to_rgb(0, 128, 128, &rgb);
    assert_eq(load8(&rgb + 0), 0, "Y=0 -> R = 0");
    _jpeg_ycc_to_rgb(200, 128, 255, &rgb);
    assert_eq(load8(&rgb + 0), 255, "Cr=255 -> R clamps to 255");
    return 0;
}

fn test_decode_color444() {
    var lo = 0;
    var b = fx_jpeg_ycc_8x8(&lo);
    var err = 0;
    var img = chitra_jpeg_decode(b, lo, &err);
    assert(img != 0, "4:4:4 decode returns an image");
    assert_eq(err, 0, "no error");
    assert_eq(chitra_image_width(img), 8, "width 8");
    assert_eq(chitra_image_channels(img), 4, "4 channels");
    var px = chitra_image_pixels(img);
    assert_eq(load8(px + 0), 129, "pixel0 R = 129 (Y=129, neutral chroma)");
    assert_eq(load8(px + 1), 129, "pixel0 G = 129");
    assert_eq(load8(px + 2), 129, "pixel0 B = 129");
    assert_eq(load8(px + 3), 255, "pixel0 A = 255");
    assert_eq(load8(px + 63 * 4 + 1), 129, "pixel63 G = 129");
    assert_eq(chitra_image_source_color_type(img), 259, "src ctype = 0x103 (JPEG YCbCr)");
    return 0;
}

# ---- bite 7: chroma subsampling + restart markers ----

# 8x8 baseline 4:2:0 JPEG (Y H/V = 2x2, chroma 1x1). One 16x16 MCU = 4 Y blocks
# + 1 Cb + 1 Cr. Y(0,0) DC=+8 -> flat 129 over the output 8x8; remaining Y blocks
# DC diff 0; neutral chroma. Entropy: B0 00 00 00.
fn fx_jpeg_420_8x8(len_out): i64 {
    var b = alloc(162);
    var i = 0;
    store8(b + 0, 0xFF);
    store8(b + 1, 0xD8);
    store8(b + 2, 0xFF);
    store8(b + 3, 0xDB);
    store8(b + 4, 0x00);
    store8(b + 5, 0x43);
    store8(b + 6, 0x00);
    i = 0;
    while (i < 64) { store8(b + 7 + i, 1); i = i + 1; }
    store8(b + 71, 0xFF);
    store8(b + 72, 0xC0);
    store8(b + 73, 0x00);
    store8(b + 74, 0x11);
    store8(b + 75, 0x08);
    store8(b + 76, 0x00);
    store8(b + 77, 0x08);
    store8(b + 78, 0x00);
    store8(b + 79, 0x08);
    store8(b + 80, 0x03);
    store8(b + 81, 0x01);           # comp 1 (Y): id 1, H/V = 2x2, Tq 0
    store8(b + 82, 0x22);
    store8(b + 83, 0x00);
    store8(b + 84, 0x02);           # comp 2 (Cb): 1x1
    store8(b + 85, 0x11);
    store8(b + 86, 0x00);
    store8(b + 87, 0x03);           # comp 3 (Cr): 1x1
    store8(b + 88, 0x11);
    store8(b + 89, 0x00);
    store8(b + 90, 0xFF);           # DHT (same as ycc)
    store8(b + 91, 0xC4);
    store8(b + 92, 0x00);
    store8(b + 93, 0x32);
    store8(b + 94, 0x00);
    store8(b + 95, 0x00);
    store8(b + 96, 0x01);
    store8(b + 97, 0x05);
    store8(b + 98, 0x01);
    store8(b + 99, 0x01);
    store8(b + 100, 0x01);
    store8(b + 101, 0x01);
    store8(b + 102, 0x01);
    store8(b + 103, 0x01);
    store8(b + 104, 0x00);
    store8(b + 105, 0x00);
    store8(b + 106, 0x00);
    store8(b + 107, 0x00);
    store8(b + 108, 0x00);
    store8(b + 109, 0x00);
    store8(b + 110, 0x00);
    i = 0;
    while (i < 12) { store8(b + 111 + i, i); i = i + 1; }
    store8(b + 123, 0x10);
    store8(b + 124, 0x00);
    store8(b + 125, 0x02);
    i = 0;
    while (i < 14) { store8(b + 126 + i, 0); i = i + 1; }
    store8(b + 140, 0x00);
    store8(b + 141, 0x01);
    store8(b + 142, 0xFF);           # SOS, 3 components
    store8(b + 143, 0xDA);
    store8(b + 144, 0x00);
    store8(b + 145, 0x0C);
    store8(b + 146, 0x03);
    store8(b + 147, 0x01);
    store8(b + 148, 0x00);
    store8(b + 149, 0x02);
    store8(b + 150, 0x00);
    store8(b + 151, 0x03);
    store8(b + 152, 0x00);
    store8(b + 153, 0x00);
    store8(b + 154, 0x3F);
    store8(b + 155, 0x00);
    store8(b + 156, 0xB0);           # entropy: Y(0,0)=DC+8, others 0; chroma 0
    store8(b + 157, 0x00);
    store8(b + 158, 0x00);
    store8(b + 159, 0x00);
    store8(b + 160, 0xFF);
    store8(b + 161, 0xD9);
    store64(len_out, 162);
    return b;
}

# 16x8 baseline grayscale JPEG with a restart interval of 1 MCU. Two MCUs (one
# 8x8 block each) separated by an RST0 marker; each MCU's DC=+8 -> flat 129.
# Entropy: B0 00 (MCU0) FF D0 (RST0) B0 00 (MCU1).
fn fx_jpeg_gray_restart(len_out): i64 {
    var b = alloc(160);
    var i = 0;
    store8(b + 0, 0xFF);
    store8(b + 1, 0xD8);
    store8(b + 2, 0xFF);
    store8(b + 3, 0xDB);
    store8(b + 4, 0x00);
    store8(b + 5, 0x43);
    store8(b + 6, 0x00);
    i = 0;
    while (i < 64) { store8(b + 7 + i, 1); i = i + 1; }
    store8(b + 71, 0xFF);
    store8(b + 72, 0xC0);
    store8(b + 73, 0x00);
    store8(b + 74, 0x0B);
    store8(b + 75, 0x08);
    store8(b + 76, 0x00);
    store8(b + 77, 0x08);            # Y = 8
    store8(b + 78, 0x00);
    store8(b + 79, 0x10);            # X = 16
    store8(b + 80, 0x01);
    store8(b + 81, 0x01);
    store8(b + 82, 0x11);
    store8(b + 83, 0x00);
    store8(b + 84, 0xFF);            # DHT
    store8(b + 85, 0xC4);
    store8(b + 86, 0x00);
    store8(b + 87, 0x32);
    store8(b + 88, 0x00);
    store8(b + 89, 0x00);
    store8(b + 90, 0x01);
    store8(b + 91, 0x05);
    store8(b + 92, 0x01);
    store8(b + 93, 0x01);
    store8(b + 94, 0x01);
    store8(b + 95, 0x01);
    store8(b + 96, 0x01);
    store8(b + 97, 0x01);
    store8(b + 98, 0x00);
    store8(b + 99, 0x00);
    store8(b + 100, 0x00);
    store8(b + 101, 0x00);
    store8(b + 102, 0x00);
    store8(b + 103, 0x00);
    store8(b + 104, 0x00);
    i = 0;
    while (i < 12) { store8(b + 105 + i, i); i = i + 1; }
    store8(b + 117, 0x10);
    store8(b + 118, 0x00);
    store8(b + 119, 0x02);
    i = 0;
    while (i < 14) { store8(b + 120 + i, 0); i = i + 1; }
    store8(b + 134, 0x00);
    store8(b + 135, 0x01);
    store8(b + 136, 0xFF);           # DRI, interval = 1
    store8(b + 137, 0xDD);
    store8(b + 138, 0x00);
    store8(b + 139, 0x04);
    store8(b + 140, 0x00);
    store8(b + 141, 0x01);
    store8(b + 142, 0xFF);           # SOS
    store8(b + 143, 0xDA);
    store8(b + 144, 0x00);
    store8(b + 145, 0x08);
    store8(b + 146, 0x01);
    store8(b + 147, 0x01);
    store8(b + 148, 0x00);
    store8(b + 149, 0x00);
    store8(b + 150, 0x3F);
    store8(b + 151, 0x00);
    store8(b + 152, 0xB0);           # MCU0 entropy
    store8(b + 153, 0x00);
    store8(b + 154, 0xFF);           # RST0
    store8(b + 155, 0xD0);
    store8(b + 156, 0xB0);           # MCU1 entropy
    store8(b + 157, 0x00);
    store8(b + 158, 0xFF);
    store8(b + 159, 0xD9);
    store64(len_out, 160);
    return b;
}

fn test_decode_420() {
    var lo = 0;
    var b = fx_jpeg_420_8x8(&lo);
    var err = 0;
    var img = chitra_jpeg_decode(b, lo, &err);
    assert(img != 0, "4:2:0 decode returns an image");
    assert_eq(err, 0, "no error");
    assert_eq(chitra_image_width(img), 8, "width 8");
    assert_eq(chitra_image_height(img), 8, "height 8");
    var px = chitra_image_pixels(img);
    assert_eq(load8(px + 0), 129, "pixel0 R = 129");
    assert_eq(load8(px + 1), 129, "pixel0 G = 129");
    assert_eq(load8(px + 2), 129, "pixel0 B = 129");
    assert_eq(load8(px + 63 * 4 + 0), 129, "pixel63 R = 129");
    assert_eq(chitra_image_source_color_type(img), 259, "src ctype = 0x103 (YCbCr)");
    return 0;
}

fn test_decode_restart() {
    var lo = 0;
    var b = fx_jpeg_gray_restart(&lo);
    var err = 0;
    var img = chitra_jpeg_decode(b, lo, &err);
    assert(img != 0, "restart decode returns an image");
    assert_eq(err, 0, "no error");
    assert_eq(chitra_image_width(img), 16, "width 16");
    assert_eq(chitra_image_height(img), 8, "height 8");
    var px = chitra_image_pixels(img);
    assert_eq(load8(px + 0), 129, "MCU0 pixel(0,0) = 129");
    assert_eq(load8(px + 8 * 4 + 0), 129, "MCU1 pixel(8,0) = 129");
    assert_eq(load8(px + 15 * 4 + 0), 129, "MCU1 pixel(15,0) = 129");
    return 0;
}

