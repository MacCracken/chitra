fn test_reject_truncated() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    var err = 0;
    # Only 8 bytes available: SOF0 declares Lf=17 but the payload runs past end.
    var f = chitra_jpeg_scan_markers(b, 8, &err);
    assert_eq(f, 0, "truncated rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_TRUNCATED, "truncated err code");
    return 0;
}

fn test_reject_eoi_before_sos() {
    var lo = 0;
    var b = fx_jpeg4(&lo, 0xFF, 0xD8, 0xFF, 0xD9);   # SOI then EOI, no frame
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "EOI before SOS rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_MARKER, "premature EOI err code");
    return 0;
}

fn test_scan_dht() {
    var lo = 0;
    var b = fx_jpeg_dht_sof(&lo);
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert(f != 0, "dht+sof scan returns a frame");
    assert_eq(err, 0, "no error");
    assert_eq(chitra_jpeg_frame_huff_present(f), 1, "DC table slot 0 present");
    var t = chitra_jpeg_frame_huff(f, 0, 0);
    assert_eq(_jpeg_huff_count(t), 12, "12 symbols");
    # canonical codes for the Annex K.3.3 DC-luminance table
    assert_eq(_jpeg_huff_maxcode(t, 1), 0 - 1, "L1 maxcode = -1 (no codes)");
    assert_eq(_jpeg_huff_mincode(t, 2), 0, "L2 mincode = 0");
    assert_eq(_jpeg_huff_maxcode(t, 2), 0, "L2 maxcode = 0");
    assert_eq(_jpeg_huff_valptr(t, 2), 0, "L2 valptr = 0");
    assert_eq(_jpeg_huff_mincode(t, 3), 2, "L3 mincode = 2 (0b010)");
    assert_eq(_jpeg_huff_maxcode(t, 3), 6, "L3 maxcode = 6 (0b110)");
    assert_eq(_jpeg_huff_valptr(t, 3), 1, "L3 valptr = 1");
    assert_eq(_jpeg_huff_mincode(t, 4), 14, "L4 mincode = 14 (0b1110)");
    assert_eq(_jpeg_huff_valptr(t, 4), 6, "L4 valptr = 6");
    assert_eq(_jpeg_huff_mincode(t, 9), 510, "L9 mincode = 510");
    assert_eq(_jpeg_huff_valptr(t, 9), 11, "L9 valptr = 11");
    assert_eq(_jpeg_huff_val(t, 0), 0, "huffval[0] = 0");
    assert_eq(_jpeg_huff_val(t, 11), 11, "huffval[11] = 11");
    assert_eq(chitra_jpeg_frame_width(f), 8, "width 8 after dht");
    return 0;
}

fn test_reject_dht_class() {
    var lo = 0;
    var b = fx_jpeg_dht_bad_class(&lo, 0x20);   # Tc=2 (only 0/1 valid)
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "DHT class 2 rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_DHT, "dht class err code");
    return 0;
}

