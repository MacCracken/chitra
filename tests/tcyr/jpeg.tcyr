fn test_decode_real_gradient() {
    var lo = 0;
    var b = fx_jpeg_real_gradient(&lo);
    var err = 0;
    var img = chitra_jpeg_decode(b, lo, &err);
    assert(img != 0, "real gradient JPEG decodes");
    assert_eq(err, 0, "no error");
    assert_eq(chitra_image_width(img), 16, "width 16");
    assert_eq(chitra_image_height(img), 16, "height 16");
    assert_eq(chitra_image_source_color_type(img), 257, "grayscale JPEG -> 0x101");
    var px = chitra_image_pixels(img);
    # row 0 matches the ImageMagick reference decode byte-for-byte
    assert_eq(load8(px + 0 * 4), 255, "row0[0] = 0xff");
    assert_eq(load8(px + 1 * 4), 240, "row0[1] = 0xf0");
    assert_eq(load8(px + 2 * 4), 220, "row0[2] = 0xdc");
    assert_eq(load8(px + 3 * 4), 203, "row0[3] = 0xcb");
    assert_eq(load8(px + 4 * 4), 188, "row0[4] = 0xbc");
    assert_eq(load8(px + 7 * 4), 136, "row0[7] = 0x88");
    assert_eq(load8(px + 15 * 4), 0, "row0[15] = 0x00");
    # horizontal gradient: row 8 equals row 0
    assert_eq(load8(px + (8 * 16 + 0) * 4), 255, "row8[0] = 0xff");
    assert_eq(load8(px + (8 * 16 + 15) * 4), 0, "row8[15] = 0x00");
    return 0;
}

fn test_jpeg_decode_rgba8() {
    var lo = 0;
    var b = fx_jpeg_real_gradient(&lo);
    var w = 0;
    var hh = 0;
    var px = chitra_jpeg_decode_rgba8(b, lo, &w, &hh);
    assert(px != 0, "decode_rgba8 returns pixels");
    assert_eq(w, 16, "rgba8 width 16");
    assert_eq(hh, 16, "rgba8 height 16");
    assert_eq(load8(px + 0), 255, "rgba8 pixel0 R = 255");
    return 0;
}

fn test_image_decode_dispatch() {
    var lo = 0;
    var jb = fx_jpeg_real_gradient(&lo);
    var err = 0;
    var img = chitra_image_decode(jb, lo, &err);
    assert(img != 0, "image_decode routes JPEG");
    assert_eq(chitra_image_width(img), 16, "dispatched JPEG width 16");
    var bad[8];
    store8(&bad + 0, 0x00);
    store8(&bad + 1, 0x01);
    store8(&bad + 2, 0x02);
    store8(&bad + 3, 0x03);
    err = 0;
    var img2 = chitra_image_decode(&bad, 8, &err);
    assert_eq(img2, 0, "unknown format rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_SIGNATURE, "unknown -> SIGNATURE");
    var pm[8];
    store8(&pm + 0, 0x89);
    store8(&pm + 1, 0x50);
    store8(&pm + 2, 0x4E);
    store8(&pm + 3, 0x47);
    store8(&pm + 4, 0x0D);
    store8(&pm + 5, 0x0A);
    store8(&pm + 6, 0x1A);
    store8(&pm + 7, 0x0A);
    err = 0;
    var img3 = chitra_image_decode(&pm, 8, &err);
    assert_eq(img3, 0, "incomplete PNG fails");
    assert(chitra_err_code(err) != CHITRA_ERR_SIGNATURE, "PNG magic routed to PNG decoder");
    return 0;
}

# ---- bite 9: hardening (DC/AC category bounds, duplicate Cs) ----

# DC table whose single symbol is category 12 (out of 8-bit baseline range 0..11).
fn fx_dc_table_cat12(): i64 {
    var t = alloc(HT_SIZE);
    var bits[136];
    var i = 0;
    while (i <= 16) { store64(&bits + i * 8, 0); i = i + 1; }
    store64(&bits + 1 * 8, 1);
    store64(t + HT_COUNT, 1);
    store64(t + HT_HUFFVAL + 0 * 8, 12);
    _jpeg_huff_build(t, &bits);
    return t;
}

# DC table with a single size-0 symbol (code "0").
fn fx_dc_table_size0(): i64 {
    var t = alloc(HT_SIZE);
    var bits[136];
    var i = 0;
    while (i <= 16) { store64(&bits + i * 8, 0); i = i + 1; }
    store64(&bits + 1 * 8, 1);
    store64(t + HT_COUNT, 1);
    store64(t + HT_HUFFVAL + 0 * 8, 0);
    _jpeg_huff_build(t, &bits);
    return t;
}

# AC table whose single symbol is 0x0B (run 0, size 11 — out of baseline range).
fn fx_ac_table_s11(): i64 {
    var t = alloc(HT_SIZE);
    var bits[136];
    var i = 0;
    while (i <= 16) { store64(&bits + i * 8, 0); i = i + 1; }
    store64(&bits + 1 * 8, 1);
    store64(t + HT_COUNT, 1);
    store64(t + HT_HUFFVAL + 0 * 8, 0x0B);
    _jpeg_huff_build(t, &bits);
    return t;
}

fn test_reject_dc_oversize() {
    var dct = fx_dc_table_cat12();
    var act = fx_ac_table();
    var buf[2];
    store8(&buf + 0, 0x00);
    var rdr[48];
    _jpeg_br_init(&rdr, &buf, 2);
    var zz = alloc(512);
    var err = 0;
    var dc = _jpeg_decode_block(&rdr, dct, act, 0, zz, &err);
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_ENTROPY, "DC category 12 rejected");
    return 0;
}

fn test_reject_ac_oversize() {
    var dct = fx_dc_table_size0();
    var act = fx_ac_table_s11();
    var buf[2];
    store8(&buf + 0, 0x00);
    var rdr[48];
    _jpeg_br_init(&rdr, &buf, 2);
    var zz = alloc(512);
    var err = 0;
    var dc = _jpeg_decode_block(&rdr, dct, act, 0, zz, &err);
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_ENTROPY, "AC size 11 rejected");
    return 0;
}

fn test_reject_dup_cs() {
    var lo = 0;
    var b = fx_jpeg_ycc_8x8(&lo);
    store8(b + 149, 0x01);   # SOS Cs2 = 1, duplicating Cs1
    var err = 0;
    var img = chitra_jpeg_decode(b, lo, &err);
    assert_eq(img, 0, "duplicate SOS Cs rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_SOS, "dup Cs -> SOS error");
    return 0;
}

