# tests/tcyr/jpeg.tcyr — JPEG (JFIF baseline) marker framing, SOF0 + DQT parse,
# and non-baseline / malformed rejection (0.3.0, bites 1-2). Self-contained CPU
# suite (own main + assert_summary), standalone like error.tcyr/png.tcyr:
# include the lib chain + the assert harness. Fixtures are tiny hand-built JPEG
# marker streams embedded as byte arrays (no file I/O).
include "src/lib.cyr"
include "lib/assert.cyr"

# ================================================================
# Fixture builders
# ================================================================

# Minimal valid baseline header: SOI + SOF0(8x8, 8-bit, 3 comp, 4:2:0) + SOS.
# No DQT (SOF parse does not require one). The scan stops at SOS.
fn fx_jpeg_baseline(len_out): i64 {
    var b = alloc(23);
    store8(b + 0, 0xFF);    # SOI
    store8(b + 1, 0xD8);
    store8(b + 2, 0xFF);    # SOF0
    store8(b + 3, 0xC0);
    store8(b + 4, 0x00);    # Lf = 17
    store8(b + 5, 0x11);
    store8(b + 6, 0x08);    # P = 8
    store8(b + 7, 0x00);    # Y = 8
    store8(b + 8, 0x08);
    store8(b + 9, 0x00);    # X = 8
    store8(b + 10, 0x08);
    store8(b + 11, 0x03);   # Nf = 3
    store8(b + 12, 0x01);   # comp 1: id=1
    store8(b + 13, 0x22);   #         H=2 V=2
    store8(b + 14, 0x00);   #         Tq=0
    store8(b + 15, 0x02);   # comp 2: id=2
    store8(b + 16, 0x11);   #         H=1 V=1
    store8(b + 17, 0x01);   #         Tq=1
    store8(b + 18, 0x03);   # comp 3: id=3
    store8(b + 19, 0x11);   #         H=1 V=1
    store8(b + 20, 0x01);   #         Tq=1
    store8(b + 21, 0xFF);   # SOS (scan boundary)
    store8(b + 22, 0xDA);
    store64(len_out, 23);
    return b;
}

# Baseline with a leading DQT (table 0, 8-bit, values k+1 for k in 0..63).
fn fx_jpeg_dqt_sof(len_out): i64 {
    var b = alloc(92);
    store8(b + 0, 0xFF);    # SOI
    store8(b + 1, 0xD8);
    store8(b + 2, 0xFF);    # DQT
    store8(b + 3, 0xDB);
    store8(b + 4, 0x00);    # Lq = 67 (2 + 1 + 64)
    store8(b + 5, 0x43);
    store8(b + 6, 0x00);    # Pq=0 Tq=0
    var k = 0;
    while (k < 64) {
        store8(b + 7 + k, k + 1);
        k = k + 1;
    }
    store8(b + 71, 0xFF);   # SOF0
    store8(b + 72, 0xC0);
    store8(b + 73, 0x00);   # Lf = 17
    store8(b + 74, 0x11);
    store8(b + 75, 0x08);   # P = 8
    store8(b + 76, 0x00);   # Y = 8
    store8(b + 77, 0x08);
    store8(b + 78, 0x00);   # X = 8
    store8(b + 79, 0x08);
    store8(b + 80, 0x03);   # Nf = 3
    store8(b + 81, 0x01);   # comp 1: id=1 H=2 V=2 Tq=0
    store8(b + 82, 0x22);
    store8(b + 83, 0x00);
    store8(b + 84, 0x02);   # comp 2: id=2 H=1 V=1 Tq=1
    store8(b + 85, 0x11);
    store8(b + 86, 0x01);
    store8(b + 87, 0x03);   # comp 3: id=3 H=1 V=1 Tq=1
    store8(b + 88, 0x11);
    store8(b + 89, 0x01);
    store8(b + 90, 0xFF);   # SOS
    store8(b + 91, 0xDA);
    store64(len_out, 92);
    return b;
}

# A 4-byte SOI + one marker stream, for cases that reject on the marker itself.
fn fx_jpeg4(len_out, b0, b1, b2, b3): i64 {
    var b = alloc(4);
    store8(b + 0, b0);
    store8(b + 1, b1);
    store8(b + 2, b2);
    store8(b + 3, b3);
    store64(len_out, 4);
    return b;
}

# SOI + a single bad DQT table header byte (PqTq), Lq=3, no table body needed.
fn fx_jpeg_dqt_bad(len_out, pqtq): i64 {
    var b = alloc(7);
    store8(b + 0, 0xFF);
    store8(b + 1, 0xD8);
    store8(b + 2, 0xFF);
    store8(b + 3, 0xDB);
    store8(b + 4, 0x00);
    store8(b + 5, 0x03);
    store8(b + 6, pqtq);
    store64(len_out, 7);
    return b;
}

# ================================================================
# _cur_u16_be (added to png_chunks.cyr for JPEG segment lengths)
# ================================================================
fn test_cur_u16_be() {
    var buf[2];
    store8(&buf + 0, 0x12);
    store8(&buf + 1, 0x34);
    var cur[24];
    _cur_init(&cur, &buf, 2);
    assert_eq(_cur_u16_be(&cur), 4660, "u16_be = 0x1234");
    assert_eq(_cur_pos(&cur), 2, "pos advanced 2");
    return 0;
}

# ================================================================
# Signature (SOI 0xFFD8)
# ================================================================
fn test_signature() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    assert_eq(chitra_jpeg_check_signature(b, lo), 1, "valid SOI signature");
    store8(b + 1, 0xD9);
    assert_eq(chitra_jpeg_check_signature(b, lo), 0, "bad SOI rejected");
    var one = 1;
    assert_eq(chitra_jpeg_check_signature(b, one), 0, "len<2 rejected");
    return 0;
}

# ================================================================
# Baseline header scan fills frame header + component sampling factors
# ================================================================
fn test_scan_baseline() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert(f != 0, "baseline scan returns a frame");
    assert_eq(err, 0, "no error on baseline");
    assert_eq(chitra_jpeg_frame_width(f), 8, "width 8");
    assert_eq(chitra_jpeg_frame_height(f), 8, "height 8");
    assert_eq(chitra_jpeg_frame_precision(f), 8, "precision 8");
    assert_eq(chitra_jpeg_frame_num_components(f), 3, "3 components");
    assert_eq(chitra_jpeg_frame_seen_sof(f), 1, "seen sof");
    # component sampling factors (4:2:0 — comp 0 is 2x2, chroma 1x1)
    assert_eq(chitra_jpeg_frame_max_h(f), 2, "max_h 2");
    assert_eq(chitra_jpeg_frame_max_v(f), 2, "max_v 2");
    assert_eq(chitra_jpeg_frame_comp_id(f, 0), 1, "comp0 id 1");
    assert_eq(chitra_jpeg_frame_comp_h(f, 0), 2, "comp0 H 2");
    assert_eq(chitra_jpeg_frame_comp_v(f, 0), 2, "comp0 V 2");
    assert_eq(chitra_jpeg_frame_comp_tq(f, 0), 0, "comp0 Tq 0");
    assert_eq(chitra_jpeg_frame_comp_id(f, 1), 2, "comp1 id 2");
    assert_eq(chitra_jpeg_frame_comp_h(f, 1), 1, "comp1 H 1");
    assert_eq(chitra_jpeg_frame_comp_tq(f, 1), 1, "comp1 Tq 1");
    assert_eq(chitra_jpeg_frame_comp_id(f, 2), 3, "comp2 id 3");
    return 0;
}

# ================================================================
# DQT parse: quant table present + values stored in spec (zig-zag) order
# ================================================================
fn test_scan_dqt() {
    var lo = 0;
    var b = fx_jpeg_dqt_sof(&lo);
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert(f != 0, "dqt+sof scan returns a frame");
    assert_eq(err, 0, "no error");
    assert_eq(chitra_jpeg_frame_quant_present(f), 1, "quant table 0 present (bit 0)");
    assert_eq(chitra_jpeg_frame_quant(f, 0, 0), 1, "quant[0][0] = 1");
    assert_eq(chitra_jpeg_frame_quant(f, 0, 63), 64, "quant[0][63] = 64");
    # SOF still parsed after the DQT
    assert_eq(chitra_jpeg_frame_width(f), 8, "width 8 after dqt");
    assert_eq(chitra_jpeg_frame_max_h(f), 2, "max_h 2 after dqt");
    return 0;
}

# ================================================================
# Non-baseline modes are rejected with distinct codes
# ================================================================
fn test_reject_progressive() {
    var lo = 0;
    var b = fx_jpeg4(&lo, 0xFF, 0xD8, 0xFF, 0xC2);   # SOF2
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "progressive rejected (null frame)");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_PROGRESSIVE, "progressive err code");
    return 0;
}

fn test_reject_arithmetic() {
    var lo = 0;
    var b = fx_jpeg4(&lo, 0xFF, 0xD8, 0xFF, 0xCA);   # SOF10 arithmetic
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "arithmetic rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_ARITHMETIC, "arithmetic err code");
    return 0;
}

fn test_reject_mode() {
    var lo = 0;
    var b = fx_jpeg4(&lo, 0xFF, 0xD8, 0xFF, 0xC3);   # SOF3 lossless
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "lossless mode rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_MODE, "mode err code");
    return 0;
}

fn test_reject_precision12() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    store8(b + 6, 0x0C);   # precision = 12
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "precision 12 rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_PRECISION, "precision err code");
    return 0;
}

fn test_reject_components() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    store8(b + 11, 0x04);   # Nf = 4
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "4-component rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_COMPONENTS, "components err code");
    return 0;
}

# Sampling factor 0 — the CVE-2018-11212 divide-by-zero guard.
fn test_reject_sampling_zero() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    store8(b + 13, 0x02);   # comp 1 H/V = 0x02 -> H=0, V=2
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "H=0 sampling factor rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_SOF, "zero-factor err code");
    return 0;
}

# Sampling factor > 4.
fn test_reject_sampling_big() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    store8(b + 13, 0x52);   # comp 1 H/V = 0x52 -> H=5, V=2
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "H=5 sampling factor rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_SOF, "big-factor err code");
    return 0;
}

# Duplicate component id.
fn test_reject_dup_component_id() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    store8(b + 15, 0x01);   # comp 2 id = 1 (duplicates comp 1)
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "duplicate component id rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_SOF, "dup-id err code");
    return 0;
}

# DQT with 16-bit precision (Pq=1) — baseline is 8-bit only.
fn test_reject_dqt_precision() {
    var lo = 0;
    var b = fx_jpeg_dqt_bad(&lo, 0x10);   # Pq=1 Tq=0
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "16-bit DQT rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_DQT, "dqt precision err code");
    return 0;
}

# DQT with table id >= 4.
fn test_reject_dqt_tableid() {
    var lo = 0;
    var b = fx_jpeg_dqt_bad(&lo, 0x04);   # Pq=0 Tq=4
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "DQT table id 4 rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_DQT, "dqt tableid err code");
    return 0;
}

fn test_reject_bad_signature() {
    var lo = 0;
    var b = fx_jpeg4(&lo, 0x00, 0x01, 0x02, 0x03);
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "non-JPEG rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_SIGNATURE, "signature err code");
    return 0;
}

fn test_reject_truncated() {
    var lo = 0;
    var b = fx_jpeg_baseline(&lo);
    var err = 0;
    # Only 8 bytes available: SOF0 declares Lf=17 but the payload runs past end.
    var f = chitra_jpeg_scan_markers(b, 8, &err);
    assert_eq(f, 0, "truncated rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_TRUNCATED, "truncated err code");
    return 0;
}

fn test_reject_eoi_before_sos() {
    var lo = 0;
    var b = fx_jpeg4(&lo, 0xFF, 0xD8, 0xFF, 0xD9);   # SOI then EOI, no frame
    var err = 0;
    var f = chitra_jpeg_scan_markers(b, lo, &err);
    assert_eq(f, 0, "EOI before SOS rejected");
    assert_eq(chitra_err_code(err), CHITRA_ERR_JPEG_MARKER, "premature EOI err code");
    return 0;
}

fn main() {
    test_cur_u16_be();
    test_signature();
    test_scan_baseline();
    test_scan_dqt();
    test_reject_progressive();
    test_reject_arithmetic();
    test_reject_mode();
    test_reject_precision12();
    test_reject_components();
    test_reject_sampling_zero();
    test_reject_sampling_big();
    test_reject_dup_component_id();
    test_reject_dqt_precision();
    test_reject_dqt_tableid();
    test_reject_bad_signature();
    test_reject_truncated();
    test_reject_eoi_before_sos();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
