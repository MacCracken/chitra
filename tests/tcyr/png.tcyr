fn test_decode_graya16() {
    var lo = 0;
    var bytes = fx_graya16_2x1(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "graya16 ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 18, 18, 18, 171, "graya16 px0");
    _assert_px(px, 1, 255, 255, 255, 0, "graya16 px1");
    return 0;
}

fn test_decode_rgba16() {
    var lo = 0;
    var bytes = fx_rgba16_2x1(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "rgba16 ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 18, 86, 154, 222, "rgba16 px0");
    _assert_px(px, 1, 202, 186, 222, 190, "rgba16 px1");
    return 0;
}

fn test_decode_gray16_trns() {
    var lo = 0;
    var bytes = fx_gray16_trns_2x1(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "gray16t ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 18, 18, 18, 0, "gray16t px0 keyed");
    _assert_px(px, 1, 255, 255, 255, 255, "gray16t px1");
    return 0;
}

