# ================================================================
# chitra_image_free is a documented no-op; safe on a real img + 0.
# ================================================================
fn test_image_free() {
    var lo = 0;
    var bytes = fx_gray8_2x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert_eq(chitra_image_free(img), 0, "free img -> 0");
    assert_eq(chitra_image_free(0), 0, "free null -> 0");
    return 0;
}

# ================================================================
# 0.2.0 — bit depth 16: each big-endian sample truncates to its HIGH
# byte (the same 16->8 reduction kii's terminal path used).
# ================================================================
fn test_decode_rgb16() {
    var lo = 0;
    var bytes = fx_rgb16_2x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "rgb16 decode ok");
    assert_eq(err, 0, "rgb16 no err");
    assert_eq(chitra_image_width(img), 2, "rgb16 w=2");
    assert_eq(chitra_image_height(img), 2, "rgb16 h=2");
    assert_eq(chitra_image_channels(img), 4, "rgb16 channels=4");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 18, 86, 154, 255, "rgb16 px0 high bytes");
    _assert_px(px, 1, 255, 0, 128, 255, "rgb16 px1 high bytes");
    _assert_px(px, 2, 1, 3, 5, 255, "rgb16 px2 high bytes");
    _assert_px(px, 3, 202, 186, 222, 255, "rgb16 px3 high bytes");
    return 0;
}

# Sub(row0)+Up(row1) filters at bpp=6 — proves the unfilter predictors
# thread the 16-bit byte-stride correctly (reconstruct fx_rgb16_2x2).
fn test_decode_rgb16_filtered() {
    var lo = 0;
    var bytes = fx_rgb16_2x2_filtered(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "rgb16 filtered decode ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 18, 86, 154, 255, "rgb16f px0");
    _assert_px(px, 1, 255, 0, 128, 255, "rgb16f px1");
    _assert_px(px, 2, 1, 3, 5, 255, "rgb16f px2");
    _assert_px(px, 3, 202, 186, 222, 255, "rgb16f px3");
    return 0;
}

fn test_decode_gray16() {
    var lo = 0;
    var bytes = fx_gray16_2x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "gray16 decode ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 18, 18, 18, 255, "gray16 px0");
    _assert_px(px, 1, 171, 171, 171, 255, "gray16 px1");
    _assert_px(px, 2, 0, 0, 0, 255, "gray16 px2");
    _assert_px(px, 3, 255, 255, 255, 255, "gray16 px3");
    return 0;
}

# color_type 3 @ depth 16 is spec-illegal -> reject loud.
fn test_reject_palette_depth16() {
    var lo = 0;
    var bytes = fx_palette_depth16_reject(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert_eq(raw, 0, "ct3+depth16 -> null");
    assert_eq(chitra_err_code(err), CHITRA_ERR_BIT_DEPTH, "ct3+depth16 -> BIT_DEPTH");
    return 0;
}

# (test_reject_depth1 removed at 0.2.1 — sub-byte depths 1/2/4 for ct0/ct3
#  are now decoded; see tests/tcyr/subbyte.tcyr. ct2/4/6 at sub-byte depth
#  remain rejected — covered there.)

# ================================================================
# 0.2.0 hardening parity: NO_IDAT distinct code, IEND-length guard,
# seen_iend signal, source_color_type accessor.
# ================================================================
fn test_reject_no_idat() {
    var lo = 0;
    var bytes = fx_no_idat(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert_eq(raw, 0, "no idat -> null");
    assert_eq(chitra_err_code(err), CHITRA_ERR_NO_IDAT, "no idat -> NO_IDAT");
    return 0;
}

fn test_reject_iend_nonzero() {
    var lo = 0;
    var bytes = fx_iend_nonzero(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert_eq(raw, 0, "iend nonzero -> null");
    assert_eq(chitra_err_code(err), CHITRA_ERR_BAD_CHUNK, "iend nonzero len -> BAD_CHUNK");
    return 0;
}

fn test_seen_iend() {
    # Normal stream: IEND present -> seen_iend == 1.
    var lo = 0;
    var bytes = fx_rgb8_2x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "seen_iend decode ok");
    assert_eq(chitra_image_seen_iend(img), 1, "iend present -> seen_iend=1");
    # Clean IEND-less end: truncate exactly before the trailing 12-byte
    # IEND chunk. Spec § 5.3 tolerance — still decodes, seen_iend == 0.
    var err2 = 0;
    var img2 = chitra_png_decode(bytes, lo - 12, &err2);
    assert(img2 != 0, "iend-less still decodes");
    assert_eq(chitra_image_seen_iend(img2), 0, "iend-less -> seen_iend=0");
    return 0;
}

fn test_source_color_type() {
    var lo = 0;
    var err = 0;
    var g = fx_gray8_2x2(&lo);
    var img_g = chitra_png_decode(g, lo, &err);
    assert_eq(chitra_image_source_color_type(img_g), 0, "src ctype grayscale=0");
    var lo2 = 0;
    var r = fx_rgb8_2x2(&lo2);
    var img_r = chitra_png_decode(r, lo2, &err);
    assert_eq(chitra_image_source_color_type(img_r), 2, "src ctype rgb=2");
    # Pixels are normalized to RGBA8 (channels=4) but the source
    # color_type is still reported faithfully.
    assert_eq(chitra_image_channels(img_r), 4, "normalized channels=4");
    return 0;
}

