# tests/tcyr/png.tcyr — byte-buffer PNG framing + IDAT inflate + unfilter
# + security (AL.P0b). Self-contained CPU suite (own main + assert_summary),
# standalone like error.tcyr: include the lib chain + the assert harness.
#
# Fixtures are tiny valid/adversarial PNGs EMBEDDED as byte arrays (no file
# I/O). They were generated by a throwaway python3 zlib+CRC script (see the
# AL.P0b report); each fx_* builder allocs a buffer, stores the exact bytes,
# and returns it with *len_out set. The expected unfiltered scanline bytes
# are asserted byte-for-byte.
include "src/lib.cyr"
include "lib/assert.cyr"

# ================================================================
# Cursor: bounds-checked reads + can_read gate
# ================================================================
fn test_cursor_bounds() {
    var buf[8];
    store8(&buf + 0, 0xAB);
    store8(&buf + 1, 0x12);
    store8(&buf + 2, 0x34);
    store8(&buf + 3, 0x56);
    store8(&buf + 4, 0x78);
    var cur[24];
    _cur_init(&cur, &buf, 5);
    assert_eq(_cur_remaining(&cur), 5, "remaining=5 at start");
    assert_eq(_cur_can_read(&cur, 5), 1, "can read 5");
    assert_eq(_cur_can_read(&cur, 6), 0, "cannot read 6 (OOB)");
    assert_eq(_cur_can_read(&cur, 0 - 1), 0, "negative n rejected");
    assert_eq(_cur_u8(&cur), 0xAB, "u8 read 0");
    assert_eq(_cur_pos(&cur), 1, "pos advanced to 1");
    # big-endian u32 over bytes 1..4 = 0x12345678.
    assert_eq(_cur_u32_be(&cur), 305419896, "u32_be = 0x12345678");
    assert_eq(_cur_pos(&cur), 5, "pos advanced to 5");
    assert_eq(_cur_remaining(&cur), 0, "remaining=0 at end");
    # Reading past end returns 0 defensively, never an OOB load.
    assert_eq(_cur_u8(&cur), 0, "u8 past end = 0 (no OOB)");
    return 0;
}

# ================================================================
# Signature check
# ================================================================
fn test_signature() {
    var lo = 0;
    var bytes = fx_rgba8_2x2(&lo);
    assert_eq(chitra_png_check_signature(bytes, lo), 1, "valid PNG signature");
    # Corrupt the high-bit magic byte.
    store8(bytes, 0x88);
    assert_eq(chitra_png_check_signature(bytes, lo), 0, "bad signature rejected");
    # Too-short input cannot match.
    assert_eq(chitra_png_check_signature(bytes, 4), 0, "short input rejected");
    return 0;
}

# ================================================================
# color_type -> channels
# ================================================================
fn test_color_channels() {
    assert_eq(chitra_png_color_channels(0), 1, "grey=1ch");
    assert_eq(chitra_png_color_channels(2), 3, "rgb=3ch");
    assert_eq(chitra_png_color_channels(3), 1, "palette=1ch");
    assert_eq(chitra_png_color_channels(4), 2, "grey+alpha=2ch");
    assert_eq(chitra_png_color_channels(6), 4, "rgba=4ch");
    assert_eq(chitra_png_color_channels(5), 0 - 1, "unknown color type=-1");
    return 0;
}

# ================================================================
# Paeth predictor edge cases (spec § 9.4)
# ================================================================
fn test_paeth() {
    assert_eq(_chitra_paeth(0, 0, 0), 0, "paeth zeros");
    # a+b-c estimate equals a -> picks a (tie left).
    assert_eq(_chitra_paeth(10, 10, 10), 10, "paeth equal -> a");
    # Classic: a=1,b=2,c=3 -> p=0; pa=1,pb=2,pc=3 -> a.
    assert_eq(_chitra_paeth(1, 2, 3), 1, "paeth picks a");
    # a=200,b=100,c=50 -> p=250; pa=50,pb=150,pc=200 -> a.
    assert_eq(_chitra_paeth(200, 100, 50), 200, "paeth picks a (big)");
    return 0;
}

# ================================================================
# Unfilter one row — None / Sub / Up / Average / Paeth + bad byte
# ================================================================
fn test_unfilter_rows() {
    var prev[4];
    var curr[4];
    var out[4];
    # None: passthrough.
    store8(&curr + 0, 5); store8(&curr + 1, 6);
    store8(&curr + 2, 7); store8(&curr + 3, 8);
    assert_eq(_chitra_unfilter_row(&prev, &curr, &out, 4, 1, 0), 0, "none ok");
    assert_eq(load8(&out + 0), 5, "none[0]");
    assert_eq(load8(&out + 3), 8, "none[3]");
    # Sub bpp=1: out[i]=in[i]+out[i-1]; in=[5,6,7,8] -> 5,11,18,26.
    assert_eq(_chitra_unfilter_row(&prev, &curr, &out, 4, 1, 1), 0, "sub ok");
    assert_eq(load8(&out + 0), 5, "sub[0]");
    assert_eq(load8(&out + 1), 11, "sub[1]");
    assert_eq(load8(&out + 3), 26, "sub[3]");
    # Up: prev=[10,20,30,40], in=[5,6,7,8] -> 15,26,37,48.
    store8(&prev + 0, 10); store8(&prev + 1, 20);
    store8(&prev + 2, 30); store8(&prev + 3, 40);
    assert_eq(_chitra_unfilter_row(&prev, &curr, &out, 4, 1, 2), 0, "up ok");
    assert_eq(load8(&out + 0), 15, "up[0]");
    assert_eq(load8(&out + 3), 48, "up[3]");
    # Average bpp=1: out[i]=in[i]+floor((left+up)/2).
    # in=[5,6,7,8] prev=[10,20,30,40]: out0=5+floor((0+10)/2)=10;
    # out1=6+floor((10+20)/2)=6+15=21; out2=7+floor((21+30)/2)=7+25=32;
    # out3=8+floor((32+40)/2)=8+36=44.
    assert_eq(_chitra_unfilter_row(&prev, &curr, &out, 4, 1, 3), 0, "avg ok");
    assert_eq(load8(&out + 0), 10, "avg[0]");
    assert_eq(load8(&out + 1), 21, "avg[1]");
    assert_eq(load8(&out + 2), 32, "avg[2]");
    assert_eq(load8(&out + 3), 44, "avg[3]");
    # Bad filter byte -> -1.
    assert_eq(_chitra_unfilter_row(&prev, &curr, &out, 4, 1, 9), 0 - 1, "bad filter -1");
    return 0;
}

# ================================================================
# Full parse: rgba8 2x2, filter None — IHDR + inflate + unfilter
# ================================================================
fn test_parse_rgba8_2x2() {
    var lo = 0;
    var bytes = fx_rgba8_2x2(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert(raw != 0, "parse rgba8 2x2 ok");
    assert_eq(err, 0, "no error set");
    assert_eq(chitra_raw_width(raw), 2, "width 2");
    assert_eq(chitra_raw_height(raw), 2, "height 2");
    assert_eq(chitra_raw_bit_depth(raw), 8, "bit_depth 8");
    assert_eq(chitra_raw_color_type(raw), 6, "color_type 6");
    assert_eq(chitra_raw_channels(raw), 4, "channels 4");
    assert_eq(chitra_raw_scanlines_len(raw), 16, "scanlines 16 bytes");
    # Type-6 depth-8 None filter -> unfiltered bytes ARE the pixels.
    var sl = chitra_raw_scanlines(raw);
    assert_eq(load8(sl + 0), 255, "px0 R");
    assert_eq(load8(sl + 1), 0, "px0 G");
    assert_eq(load8(sl + 2), 0, "px0 B");
    assert_eq(load8(sl + 3), 255, "px0 A");
    assert_eq(load8(sl + 4), 0, "px1 R");
    assert_eq(load8(sl + 5), 255, "px1 G");
    assert_eq(load8(sl + 7), 255, "px1 A");
    assert_eq(load8(sl + 8), 0, "px2 R");
    assert_eq(load8(sl + 10), 255, "px2 B");
    assert_eq(load8(sl + 12), 255, "px3 R");
    assert_eq(load8(sl + 13), 255, "px3 G");
    assert_eq(load8(sl + 14), 0, "px3 B");
    assert_eq(load8(sl + 15), 128, "px3 A");
    return 0;
}

# ================================================================
# Full parse: rgb8 2x2 with Sub (row0) + Up (row1) filters.
# Proves the unfilter predictors reconstruct the exact pixels.
# ================================================================
fn test_parse_rgb8_filtered() {
    var lo = 0;
    var bytes = fx_rgb8_2x2_filtered(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert(raw != 0, "parse rgb8 filtered ok");
    assert_eq(chitra_raw_color_type(raw), 2, "color_type 2");
    assert_eq(chitra_raw_channels(raw), 3, "channels 3");
    assert_eq(chitra_raw_scanlines_len(raw), 12, "scanlines 12 bytes");
    var sl = chitra_raw_scanlines(raw);
    # row0: 10,20,30, 40,50,60   row1: 70,80,90, 100,110,120
    assert_eq(load8(sl + 0), 10, "r0px0 R");
    assert_eq(load8(sl + 1), 20, "r0px0 G");
    assert_eq(load8(sl + 2), 30, "r0px0 B");
    assert_eq(load8(sl + 3), 40, "r0px1 R");
    assert_eq(load8(sl + 5), 60, "r0px1 B");
    assert_eq(load8(sl + 6), 70, "r1px0 R");
    assert_eq(load8(sl + 8), 90, "r1px0 B");
    assert_eq(load8(sl + 9), 100, "r1px1 R");
    assert_eq(load8(sl + 10), 110, "r1px1 G");
    assert_eq(load8(sl + 11), 120, "r1px1 B");
    return 0;
}

# ================================================================
# Full parse: 1x1 rgba8 with Paeth filter (row0 paeth(0,0,0)=0).
# ================================================================
fn test_parse_paeth() {
    var lo = 0;
    var bytes = fx_rgba8_1x1_paeth(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert(raw != 0, "parse 1x1 paeth ok");
    assert_eq(chitra_raw_width(raw), 1, "width 1");
    assert_eq(chitra_raw_scanlines_len(raw), 4, "scanlines 4 bytes");
    var sl = chitra_raw_scanlines(raw);
    assert_eq(load8(sl + 0), 123, "paeth px R");
    assert_eq(load8(sl + 1), 200, "paeth px G");
    assert_eq(load8(sl + 2), 55, "paeth px B");
    assert_eq(load8(sl + 3), 255, "paeth px A");
    return 0;
}

# ================================================================
# Adversarial: bad signature -> reject, no crash
# ================================================================
fn test_reject_bad_signature() {
    var lo = 0;
    var bytes = fx_rgba8_2x2(&lo);
    store8(bytes + 1, 0x00);   # corrupt 'P' of the magic
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert_eq(raw, 0, "bad sig -> null");
    assert(err != 0, "bad sig -> err set");
    assert_eq(chitra_err_code(err), CHITRA_ERR_SIGNATURE, "err SIGNATURE");
    return 0;
}

# ================================================================
# Adversarial: truncated stream -> reject (cut the buffer length short)
# ================================================================
fn test_reject_truncated() {
    var lo = 0;
    var bytes = fx_rgba8_2x2(&lo);
    var err = 0;
    # Claim only 40 bytes (past IHDR, mid-IDAT-header) -> truncated.
    var raw = chitra_png_parse_raw(bytes, 40, &err);
    assert_eq(raw, 0, "truncated -> null");
    assert(err != 0, "truncated -> err set");
    # Also a length shorter than even the signature.
    var err2 = 0;
    var raw2 = chitra_png_parse_raw(bytes, 5, &err2);
    assert_eq(raw2, 0, "tiny len -> null");
    assert_eq(chitra_err_code(err2), CHITRA_ERR_SIGNATURE, "tiny len -> SIGNATURE");
    return 0;
}

# ================================================================
# Adversarial: CRC mismatch (IDAT data byte flipped) -> reject
# ================================================================
fn test_reject_crc() {
    var lo = 0;
    var bytes = fx_crc_corrupt_2x2(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert_eq(raw, 0, "crc mismatch -> null");
    assert(err != 0, "crc mismatch -> err set");
    assert_eq(chitra_err_code(err), CHITRA_ERR_CRC, "err CRC");
    return 0;
}

# (test_reject_interlace removed at 0.2.1 — Adam7 is now decoded, not
#  rejected; see the interlace decode tests in tests/tcyr/interlace.tcyr.)

# ================================================================
# Adversarial: decompression bomb — tiny input claiming 70000x70000.
# The per-side dimension cap (65535) trips before any alloc.
# ================================================================
fn test_reject_bomb() {
    var lo = 0;
    var bytes = fx_bomb_huge_dims(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert_eq(raw, 0, "bomb -> null");
    assert_eq(chitra_err_code(err), CHITRA_ERR_DIMENSIONS, "err DIMENSIONS");
    return 0;
}

# ================================================================
# AL.P0d color pass — canonical RGBA8 per color type @ depth 8.
# Each fixture is decoded end-to-end via chitra_png_decode and the
# RGBA8 pixels are asserted exactly (ground truth from a reference
# decoder re-decoding the same fixture bytes — see the AL.P0d report).
# ================================================================

# Helper: assert one RGBA8 pixel at index `i` in the pixel buffer.
fn _assert_px(px, i, r, g, b, a, tag) {
    var o = px + i * 4;
    assert_eq(load8(o + 0), r, tag);
    assert_eq(load8(o + 1), g, tag);
    assert_eq(load8(o + 2), b, tag);
    assert_eq(load8(o + 3), a, tag);
    return 0;
}

# ---- color type 0 grayscale: g -> (g,g,g,255) ----
fn test_decode_gray8() {
    var lo = 0;
    var bytes = fx_gray8_2x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "gray8 decode ok");
    assert_eq(err, 0, "gray8 no err");
    assert_eq(chitra_image_width(img), 2, "gray8 w=2");
    assert_eq(chitra_image_height(img), 2, "gray8 h=2");
    assert_eq(chitra_image_channels(img), 4, "gray8 channels=4");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 10, 10, 10, 255, "gray8 px0");
    _assert_px(px, 1, 200, 200, 200, 255, "gray8 px1");
    _assert_px(px, 2, 40, 40, 40, 255, "gray8 px2");
    _assert_px(px, 3, 255, 255, 255, 255, "gray8 px3");
    return 0;
}

# ---- color type 0 grayscale + tRNS key gray=200 -> alpha 0 ----
fn test_decode_gray8_trns() {
    var lo = 0;
    var bytes = fx_gray8_2x2_trns(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "gray8 trns decode ok");
    var px = chitra_image_pixels(img);
    # Keyed gray=200 (px1) becomes transparent; the rest opaque.
    _assert_px(px, 0, 10, 10, 10, 255, "gray8t px0 opaque");
    _assert_px(px, 1, 200, 200, 200, 0, "gray8t px1 keyed");
    _assert_px(px, 2, 40, 40, 40, 255, "gray8t px2 opaque");
    _assert_px(px, 3, 255, 255, 255, 255, "gray8t px3 opaque");
    return 0;
}

# ---- color type 2 truecolor RGB: (r,g,b) -> (r,g,b,255) ----
fn test_decode_rgb8() {
    var lo = 0;
    var bytes = fx_rgb8_2x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "rgb8 decode ok");
    assert_eq(chitra_image_width(img), 2, "rgb8 w=2");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 255, 0, 0, 255, "rgb8 px0 red");
    _assert_px(px, 1, 0, 255, 0, 255, "rgb8 px1 green");
    _assert_px(px, 2, 0, 0, 255, 255, "rgb8 px2 blue");
    _assert_px(px, 3, 10, 20, 30, 255, "rgb8 px3");
    return 0;
}

# ---- color type 2 RGB + tRNS key (0,255,0) -> green alpha 0 ----
fn test_decode_rgb8_trns() {
    var lo = 0;
    var bytes = fx_rgb8_2x2_trns(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "rgb8 trns decode ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 255, 0, 0, 255, "rgb8t px0 opaque");
    _assert_px(px, 1, 0, 255, 0, 0, "rgb8t px1 keyed green");
    _assert_px(px, 2, 0, 0, 255, 255, "rgb8t px2 opaque");
    _assert_px(px, 3, 10, 20, 30, 255, "rgb8t px3 opaque");
    return 0;
}

# ---- color type 3 palette + tRNS per-entry alpha ----
fn test_decode_palette_trns() {
    var lo = 0;
    var bytes = fx_palette_2x2_trns(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "palette trns decode ok");
    assert_eq(err, 0, "palette trns no err");
    var px = chitra_image_pixels(img);
    # PLTE: 0=(255,0,0),1=(0,255,0),2=(0,0,255),3=(255,255,0).
    # tRNS=[0,128]: entry0 alpha 0, entry1 alpha 128, 2/3 default 255.
    # indices: 0,1 / 2,3.
    _assert_px(px, 0, 255, 0, 0, 0, "pal px0 entry0 a=0");
    _assert_px(px, 1, 0, 255, 0, 128, "pal px1 entry1 a=128");
    _assert_px(px, 2, 0, 0, 255, 255, "pal px2 entry2 a=255");
    _assert_px(px, 3, 255, 255, 0, 255, "pal px3 entry3 a=255");
    return 0;
}

# ---- color type 4 grayscale+alpha: (g,a) -> (g,g,g,a) ----
fn test_decode_graya8() {
    var lo = 0;
    var bytes = fx_graya8_2x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "graya8 decode ok");
    var px = chitra_image_pixels(img);
    # (g,a): (10,255),(200,128) / (40,0),(255,64).
    _assert_px(px, 0, 10, 10, 10, 255, "graya8 px0");
    _assert_px(px, 1, 200, 200, 200, 128, "graya8 px1");
    _assert_px(px, 2, 40, 40, 40, 0, "graya8 px2");
    _assert_px(px, 3, 255, 255, 255, 64, "graya8 px3");
    return 0;
}

# ---- color type 6 truecolor+alpha: passthrough ----
# Reuses the AL.P0b fx_rgba8_2x2 fixture, now run through the full
# public decode (parse + color pass) — alpha is preserved verbatim.
fn test_decode_rgba8() {
    var lo = 0;
    var bytes = fx_rgba8_2x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "rgba8 decode ok");
    assert_eq(chitra_image_channels(img), 4, "rgba8 channels=4");
    var px = chitra_image_pixels(img);
    # Same pixels asserted on the raw scanlines in test_parse_rgba8_2x2;
    # type 6 is a passthrough so RGBA8 == scanlines.
    _assert_px(px, 0, 255, 0, 0, 255, "rgba8 px0");
    _assert_px(px, 1, 0, 255, 0, 255, "rgba8 px1");
    _assert_px(px, 3, 255, 255, 0, 128, "rgba8 px3 alpha=128");
    return 0;
}

# ---- convenience wrapper chitra_png_decode_rgba8 ----
fn test_decode_rgba8_convenience() {
    var lo = 0;
    var bytes = fx_rgb8_2x2(&lo);
    var w = 0;
    var h = 0;
    var px = chitra_png_decode_rgba8(bytes, lo, &w, &h);
    assert(px != 0, "convenience returns pixels");
    assert_eq(w, 2, "convenience w=2");
    assert_eq(h, 2, "convenience h=2");
    _assert_px(px, 0, 255, 0, 0, 255, "convenience px0 red");
    # A bad-signature input returns 0 with w/h zeroed.
    store8(bytes, 0x00);
    var w2 = 0;
    var h2 = 0;
    var px2 = chitra_png_decode_rgba8(bytes, lo, &w2, &h2);
    assert_eq(px2, 0, "convenience bad sig -> 0");
    assert_eq(w2, 0, "convenience bad sig -> w=0");
    assert_eq(h2, 0, "convenience bad sig -> h=0");
    return 0;
}

# ================================================================
# Adversarial (AL.P0d): palette index out of range -> reject loud,
