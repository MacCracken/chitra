    store8(b + 59, 50);
    store8(b + 60, 249);
    store8(b + 61, 255);
    store8(b + 62, 31);
    store8(b + 63, 0);
    store8(b + 64, 3);
    store8(b + 65, 230);
    store8(b + 66, 2);
    store8(b + 67, 69);
    store8(b + 68, 241);
    store8(b + 69, 28);
    store8(b + 70, 132);
    store8(b + 71, 101);
    store8(b + 72, 0);
    store8(b + 73, 0);
    store8(b + 74, 0);
    store8(b + 75, 0);
    store8(b + 76, 73);
    store8(b + 77, 69);
    store8(b + 78, 78);
    store8(b + 79, 68);
    store8(b + 80, 174);
    store8(b + 81, 66);
    store8(b + 82, 96);
    store8(b + 83, 130);
    return b;
}

fn test_reject_bad_filter_method() {
    var lo = 0;
    var bytes = fx_bad_filter_method(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert_eq(raw, 0, "bad filter method -> null");
    assert_eq(chitra_err_code(err), CHITRA_ERR_UNSUPPORTED, "filter method != 0 -> UNSUPPORTED");
    return 0;
}

fn fx_bad_filter_method(len_out): i64 {
    var b = alloc(33);
    store64(len_out, 33);
    store8(b + 0, 137);
    store8(b + 1, 80);
    store8(b + 2, 78);
    store8(b + 3, 71);
    store8(b + 4, 13);
    store8(b + 5, 10);
    store8(b + 6, 26);
    store8(b + 7, 10);
    store8(b + 8, 0);
    store8(b + 9, 0);
    store8(b + 10, 0);
    store8(b + 11, 13);
    store8(b + 12, 73);
    store8(b + 13, 72);
    store8(b + 14, 68);
    store8(b + 15, 82);
    store8(b + 16, 0);
    store8(b + 17, 0);
    store8(b + 18, 0);
    store8(b + 19, 2);
    store8(b + 20, 0);
    store8(b + 21, 0);
    store8(b + 22, 0);
    store8(b + 23, 2);
    store8(b + 24, 8);
    store8(b + 25, 2);
    store8(b + 26, 0);
    store8(b + 27, 1);
    store8(b + 28, 0);
    store8(b + 29, 228);
    store8(b + 30, 207);
    store8(b + 31, 171);
    store8(b + 32, 50);
    return b;
}

