# tests/tcyr/subbyte.tcyr — sub-byte bit depths 1/2/4 (chitra 0.2.1).
# grayscale (ct0) + palette (ct3) at depths 1/2/4 (MSB-first, byte-padded
# rows) + ct2-at-depth-4 rejection. Fixtures are python-packed (exact bit
# control) and cross-checked against ImageMagick. Standalone CPU suite.
include "src/lib.cyr"
include "lib/assert.cyr"

fn _assert_px(px, i, r, g, b, a, tag) {
    var o = px + i * 4;
    assert_eq(load8(o + 0), r, tag);
    assert_eq(load8(o + 1), g, tag);
    assert_eq(load8(o + 2), b, tag);
    assert_eq(load8(o + 3), a, tag);
    return 0;
}

fn test_gray1_8x1() {
    var lo = 0;
    var bytes = fx_gray1_8x1(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "gray1_8x1 decode ok");
    assert_eq(err, 0, "gray1_8x1 no err");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 0, 0, 0, 255, "gray1_8x1 px0");
    _assert_px(px, 1, 255, 255, 255, 255, "gray1_8x1 px1");
    _assert_px(px, 2, 0, 0, 0, 255, "gray1_8x1 px2");
    _assert_px(px, 3, 255, 255, 255, 255, "gray1_8x1 px3");
    _assert_px(px, 4, 255, 255, 255, 255, "gray1_8x1 px4");
    _assert_px(px, 5, 0, 0, 0, 255, "gray1_8x1 px5");
    _assert_px(px, 6, 0, 0, 0, 255, "gray1_8x1 px6");
    _assert_px(px, 7, 255, 255, 255, 255, "gray1_8x1 px7");
    return 0;
}

fn test_gray2_4x1() {
    var lo = 0;
    var bytes = fx_gray2_4x1(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "gray2_4x1 decode ok");
    assert_eq(err, 0, "gray2_4x1 no err");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 0, 0, 0, 255, "gray2_4x1 px0");
    _assert_px(px, 1, 85, 85, 85, 255, "gray2_4x1 px1");
    _assert_px(px, 2, 170, 170, 170, 255, "gray2_4x1 px2");
    _assert_px(px, 3, 255, 255, 255, 255, "gray2_4x1 px3");
    return 0;
}

fn test_gray4_3x2() {
    var lo = 0;
    var bytes = fx_gray4_3x2(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "gray4_3x2 decode ok");
    assert_eq(err, 0, "gray4_3x2 no err");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 0, 0, 0, 255, "gray4_3x2 px0");
    _assert_px(px, 1, 85, 85, 85, 255, "gray4_3x2 px1");
    _assert_px(px, 2, 255, 255, 255, 255, "gray4_3x2 px2");
    _assert_px(px, 3, 255, 255, 255, 255, "gray4_3x2 px3");
    _assert_px(px, 4, 136, 136, 136, 255, "gray4_3x2 px4");
    _assert_px(px, 5, 17, 17, 17, 255, "gray4_3x2 px5");
    return 0;
}

fn test_pal2_4x1() {
    var lo = 0;
    var bytes = fx_pal2_4x1(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "pal2_4x1 decode ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 255, 0, 0, 255, "pal2_4x1 px0");
    _assert_px(px, 1, 0, 255, 0, 255, "pal2_4x1 px1");
    _assert_px(px, 2, 0, 0, 255, 255, "pal2_4x1 px2");
    _assert_px(px, 3, 255, 255, 0, 255, "pal2_4x1 px3");
    return 0;
}

fn test_pal1_8x1() {
    var lo = 0;
    var bytes = fx_pal1_8x1(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "pal1_8x1 decode ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 0, 0, 0, 255, "pal1_8x1 px0");
    _assert_px(px, 1, 255, 255, 255, 255, "pal1_8x1 px1");
    _assert_px(px, 2, 255, 255, 255, 255, "pal1_8x1 px2");
    _assert_px(px, 3, 0, 0, 0, 255, "pal1_8x1 px3");
    _assert_px(px, 4, 255, 255, 255, 255, "pal1_8x1 px4");
    _assert_px(px, 5, 0, 0, 0, 255, "pal1_8x1 px5");
    _assert_px(px, 6, 0, 0, 0, 255, "pal1_8x1 px6");
    _assert_px(px, 7, 255, 255, 255, 255, "pal1_8x1 px7");
    return 0;
}

fn test_pal4_trns() {
    var lo = 0;
    var bytes = fx_pal4_trns(&lo);
    var err = 0;
    var img = chitra_png_decode(bytes, lo, &err);
    assert(img != 0, "pal4_trns decode ok");
    var px = chitra_image_pixels(img);
    _assert_px(px, 0, 255, 0, 0, 0, "pal4_trns px0");
    _assert_px(px, 1, 0, 255, 0, 128, "pal4_trns px1");
    _assert_px(px, 2, 0, 0, 255, 255, "pal4_trns px2");
    return 0;
}

fn test_reject_rgb_depth4() {
    var lo = 0;
    var bytes = fx_rgb_depth4_reject(&lo);
    var err = 0;
    var raw = chitra_png_parse_raw(bytes, lo, &err);
    assert_eq(raw, 0, "ct2+depth4 -> null");
    assert_eq(chitra_err_code(err), CHITRA_ERR_BIT_DEPTH, "ct2+depth4 -> BIT_DEPTH");
    return 0;
}

